  "name": "Noisy Tool Output",
  "description": "Test if the agent can compress noisy tool outputs while retaining key diagnostic information.",
  "workspace": "task_workspaces/repo_log_parser",
  "system_goal": "Fix a failing parser test with very noisy logs.",
  "turns": [
